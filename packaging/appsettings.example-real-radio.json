{
  // MultiCAT real-radio configuration example.
  // To use: edit MultiCat.Service\appsettings.json and replace its "Radios"
  // array with an entry like the ones below, then restart the service.
  // Comments and trailing commas are allowed here.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Radios": [
    {
      // Serial radio (USB/RS-232 CAT), e.g. an Elecraft K3.
      "Name": "My Elecraft K3",
      "Protocol": "Kenwood",          // "Kenwood" (Kenwood/Elecraft/Yaesu-ASCII) or "IcomCiv"
      "Connection": "Serial",
      "Simulator": false,
      "ComPort": "COM7",              // the radio's actual CAT COM port
      "BaudRate": 38400,              // match the radio's CAT baud rate
      "ClientPorts": [
        // Driverless, works today: apps connect over TCP, no COM driver needed.
        { "PortDisplay": "TCP 4532", "Label": "rigctld (WSJT-X, fldigi)", "RigctldPort": 4532 },
        { "PortDisplay": "TCP 4533", "Label": "raw CAT over TCP", "TcpPort": 4533 }

        // Virtual COM ports (needs a signed com0com/VSP driver installed):
        // { "PortDisplay": "COM11", "Label": "N1MM Logger", "MuxPort": "COM21" }
      ]
    },
    {
      // Network radio, e.g. an Elecraft K4/K4D over Ethernet (CAT on TCP port 9200).
      "Name": "My Elecraft K4D",
      "Protocol": "Kenwood",
      "Connection": "Tcp",
      "Simulator": false,
      "Host": "192.168.1.40",         // the K4's IP, or "K4-SN1234.local"
      "TcpPort": 9200,
      "ClientPorts": [
        { "PortDisplay": "TCP 4542", "Label": "rigctld (WSJT-X, fldigi)", "RigctldPort": 4542 }
      ]
    }
  ]
}
